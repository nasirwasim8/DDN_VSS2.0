# Environment Variables Template for Cloud Run
# Copy this to your Cloud Run service's environment variables section

# Required for production
ENVIRONMENT=production

# DDN INFINIA Configuration (replace with your values)
INFINIA_ENDPOINT=https://your-infinia-endpoint.com
INFINIA_ACCESS_KEY=your-access-key
INFINIA_SECRET_KEY=your-secret-key
INFINIA_BUCKET=multimodal-search
INFINIA_REGION=us-east-1

# Optional: AWS S3 Configuration
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET=
AWS_REGION=us-east-1

# Optional: NVIDIA API for enhanced AI features
NVIDIA_API_KEY=

# LLM Enrichment Configuration
# Provider: "auto" (OpenAI first → Ollama fallback), "openai" (OpenAI only), "ollama" (local only)
LLM_PROVIDER=auto
# OpenAI API key — required for OpenAI enrichment (GPT-4o-mini vision)
OPENAI_API_KEY=sk-proj-...
# Ollama URL (default: localhost for local installs)
OLLAMA_BASE_URL=http://localhost:11434
# Vision model for Ollama fallback
LLM_MODEL=llava:7b

# Application Settings
DEBUG=false
